<script>
/* HELPERS */
function TM(){var m=document.getElementById('mm'),h=document.getElementById('ham');m.classList.toggle('open');h.classList.toggle('open');document.body.style.overflow=m.classList.contains('open')?'hidden':''}

/* CUSTOM CURSOR */
var cur=document.getElementById('cursor');
if(window.matchMedia('(pointer:fine)').matches){
  document.addEventListener('mousemove',function(e){cur.style.left=e.clientX+'px';cur.style.top=e.clientY+'px'});
  document.querySelectorAll('a,button,.svc-item,.faq-q').forEach(function(el){
    el.addEventListener('mouseenter',function(){cur.classList.add('active')});
    el.addEventListener('mouseleave',function(){cur.classList.remove('active')});
  });
}

/* NAV SCROLL */
window.addEventListener('scroll',function(){document.getElementById('nav').classList.toggle('scrolled',window.scrollY>80)});

/* GSAP */
gsap.registerPlugin(ScrollTrigger);

/* HERO — Text line reveals */
var htl=gsap.timeline({delay:.2});
htl.to('.hero-mega .line-in',{y:'0%',duration:1,stagger:.12,ease:'power3.out'})
   .to('.hero-sub-line span',{y:'0%',duration:.7,ease:'power3.out'},'-=.5')
   .to('.hero-acts',{y:'0%',duration:.6,ease:'power3.out'},'-=.3')
   .to('#heroScroll',{opacity:1,duration:.5},'-=.2');

/* Clip-path reveal on scroll — mask peels away to show image */
gsap.to('#heroMask',{
  clipPath:'polygon(0 0,100% 0,100% 0%,0 0%)',
  ease:'none',
  scrollTrigger:{trigger:'#heroSec',start:'top top',end:'80% top',scrub:.5}
});

/* Parallax hero image */
if(document.getElementById('heroImg')&&document.getElementById('heroImg').tagName==='IMG'){
  gsap.to('#heroImg',{yPercent:20,ease:'none',scrollTrigger:{trigger:'#heroSec',start:'top top',end:'bottom top',scrub:true}});
}

/* Fade out hero text on scroll */
gsap.to('#heroTxt',{opacity:0,y:-60,ease:'none',scrollTrigger:{trigger:'#heroSec',start:'30% top',end:'70% top',scrub:true}});

/* GALLERY — STACKING CARD REVEAL */
var galStack=document.getElementById('galStack');
var cards=galStack?gsap.utils.toArray('.gal-card'):[];
if(cards.length>1){
  cards.forEach(function(card,i){
    var zIdx=cards.length-i;
    gsap.set(card,{zIndex:zIdx});
    if(i<cards.length-1){
      ScrollTrigger.create({
        trigger:'.gal-stack',
        start:function(){return 'top+='+(i*(100/(cards.length)))+'% top'},
        end:function(){return 'top+='+((i+1)*(100/(cards.length)))+'% top'},
        scrub:.5,
        animation:gsap.to(card,{yPercent:-120,rotate:-(4+i*2),scale:.9,opacity:0,ease:'none'})
      });
    }
  });
  ScrollTrigger.create({trigger:'.gal-stack',start:'top top',end:'bottom bottom',pin:true});
  gsap.set('.gal',{paddingBottom:'100vh'});
}

/* STATS COUNTER */
document.querySelectorAll('.stat-n[data-count]').forEach(function(el){
  var t=parseInt(el.dataset.count);
  var suf='+';
  ScrollTrigger.create({
    trigger:el,start:'top 85%',once:true,
    onEnter:function(){
      gsap.to(el,{duration:2,ease:'power2.out',
        onUpdate:function(){var v=Math.floor(t*this.progress());el.textContent=v+suf}
      });
    }
  });
});

/* SERVICE ITEMS — stagger in */
if(document.getElementById('svcList')){
  gsap.from('.svc-item',{y:40,opacity:0,duration:.7,stagger:.08,ease:'power3.out',scrollTrigger:{trigger:'#svcList',start:'top 85%'}});
}

/* REVIEW CARDS */
if(document.getElementById('revGrid')){
  gsap.from('#revGrid .rev-card',{y:60,opacity:0,duration:.8,stagger:.1,ease:'power3.out',scrollTrigger:{trigger:'#revGrid',start:'top 85%'}});
}

/* SERVICES ACCORDION */
document.querySelectorAll('.svc-item').forEach(function(item){
  item.addEventListener('click',function(){
    var isActive=this.classList.contains('active');
    document.querySelectorAll('.svc-item').forEach(function(i){i.classList.remove('active')});
    if(!isActive) this.classList.add('active');
  });
});

/* GENERAL SECTION reveals */
gsap.utils.toArray('.sec-tag,.sec-t,.sec-sub,.info-grid,.c-stack,.hrs-table,.cta-c,.about-grid,.about-sec,.gal-single,.cat-tags,.about-quote,.gm-btn,.owner-resp,.svc-sec,.rev-sec-header,.rev-badge').forEach(function(el){
  gsap.from(el,{y:40,opacity:0,duration:.8,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 88%'}});
});
</script>
</body>
</html>