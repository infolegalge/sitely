          <span class="rev-q">"</span>
          <div class="rev-top">
            <div class="rev-avatar" style="background:{{#if (eq @index 0)}}var(--primary){{else if (eq @index 1)}}var(--dark){{else if (eq @index 2)}}linear-gradient(135deg,#0D9488,#5EEAD4){{else}}var(--accent){{/if}}">{{initial author}}</div>
