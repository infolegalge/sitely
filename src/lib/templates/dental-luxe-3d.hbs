              <div class="rev-name">{{truncate author 30}}</div>
              {{#if date}}<div class="rev-date">{{date}}</div>{{/if}}
            </div>
          </div>
          <div class="rev-card-stars">
            {{#repeat 5}}<svg viewBox="0 0 20 20"><polygon points="10,1.5 12.39,7.36 18.81,7.64 13.76,11.82 15.53,18.08 10,14.27 4.47,18.08 6.24,11.82 1.19,7.64 7.61,7.36" fill="{{star_fill ../rating num}}"/></svg>{{/repeat}}
          </div>
          <p class="rev-text">{{truncate text 300}}</p>
          {{#if owner_response}}
          <div class="owner-resp">
            <div class="owner-resp-label">მფლობელის პასუხი</div>
            <p class="owner-resp-text">{{truncate owner_response 200}}</p>
          </div>
          {{/if}}
        </div>
        {{/each}}
      {{else if (gt (len review_snippets) 0)}}
