              <div class="rev-name">Google მომხმარებელი</div>
            </div>
          </div>
          <div class="rev-card-stars">
            {{#repeat 5}}<svg viewBox="0 0 20 20"><polygon points="10,1.5 12.39,7.36 18.81,7.64 13.76,11.82 15.53,18.08 10,14.27 4.47,18.08 6.24,11.82 1.19,7.64 7.61,7.36" fill="#0D9488"/></svg>{{/repeat}}
          </div>
          <p class="rev-text">{{truncate this 300}}</p>
        </div>
        {{/each}}
      {{else}}
