<script>
/* ═══════ MOBILE MENU ═══════ */
function toggleMenu(){
  document.querySelector('.ham').classList.toggle('open');
  document.getElementById('mobileMenu').classList.toggle('open');
  document.body.style.overflow=document.getElementById('mobileMenu').classList.contains('open')?'hidden':'';
}

/* ═══════ NAV SCROLL ═══════ */
window.addEventListener('scroll',function(){
  document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>60);
});

/* ═══════ THREE.JS BACKGROUND ═══════ */
(function(){
  var canvas=document.getElementById('bgCanvas');
  if(!canvas||typeof THREE==='undefined')return;

  var w=window.innerWidth,h=window.innerHeight;
  var renderer=new THREE.WebGLRenderer({canvas:canvas,alpha:true,antialias:false});
  var dpr=window.innerWidth<768?1:Math.min(window.devicePixelRatio,1.5);
  renderer.setPixelRatio(dpr);
  renderer.setSize(w,h);

  var scene=new THREE.Scene();
  var camera=new THREE.PerspectiveCamera(60,w/h,.1,1000);
  camera.position.z=30;

  var isMobile=window.innerWidth<768;
  var count=isMobile?60:150;
  var particles=[];
  var colors=[
    new THREE.Color('#0D9488'),
    new THREE.Color('#5EEAD4'),
    new THREE.Color('#F59E0B'),
    new THREE.Color('#0EA5E9'),
    new THREE.Color('#A78BFA')
  ];

  /* Particle geometries */
  var geos=[
    new THREE.SphereGeometry(.15,8,8),
    new THREE.TorusGeometry(.12,.04,8,16),
    new THREE.IcosahedronGeometry(.14,0),
    new THREE.OctahedronGeometry(.13,0)
  ];

  for(var i=0;i<count;i++){
    var geo=geos[Math.floor(Math.random()*geos.length)];
    var col=colors[Math.floor(Math.random()*colors.length)];
    var mat=new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:Math.random()*.4+.1});
    var mesh=new THREE.Mesh(geo,mat);
    mesh.position.set(
      (Math.random()-.5)*60,
      (Math.random()-.5)*40,
      (Math.random()-.5)*40
    );
    mesh.rotation.set(Math.random()*Math.PI,Math.random()*Math.PI,0);
    mesh.userData={
      vx:(Math.random()-.5)*.008,
      vy:(Math.random()-.5)*.006,
      vz:(Math.random()-.5)*.004,
      rx:(Math.random()-.5)*.003,
      ry:(Math.random()-.5)*.003
    };
    scene.add(mesh);
    particles.push(mesh);
  }

  /* Subtle ambient light ring */
  var ringGeo=new THREE.TorusGeometry(15,.03,4,64);
  var ringMat=new THREE.MeshBasicMaterial({color:new THREE.Color('#0D9488'),transparent:true,opacity:.06});
  var ring=new THREE.Mesh(ringGeo,ringMat);
  ring.rotation.x=Math.PI*.5;
  scene.add(ring);

  var scrollY=0;
  window.addEventListener('scroll',function(){scrollY=window.pageYOffset},{ passive:true });
  window.addEventListener('resize',function(){
    w=window.innerWidth;h=window.innerHeight;
    camera.aspect=w/h;camera.updateProjectionMatrix();
    renderer.setSize(w,h);
  });

  function animate(){
    requestAnimationFrame(animate);
    var scrollFactor=scrollY*.0003;

    for(var i=0;i<particles.length;i++){
      var p=particles[i];
      p.position.x+=p.userData.vx;
      p.position.y+=p.userData.vy;
      p.position.z+=p.userData.vz;
      p.rotation.x+=p.userData.rx;
      p.rotation.y+=p.userData.ry;

      /* Wrap around bounds */
      if(p.position.x>32)p.position.x=-32;
      if(p.position.x<-32)p.position.x=32;
      if(p.position.y>22)p.position.y=-22;
      if(p.position.y<-22)p.position.y=22;
    }

    ring.rotation.z+=.001;
    camera.position.y=-scrollFactor*2;
    camera.lookAt(0,-scrollFactor,0);

    renderer.render(scene,camera);
  }
  animate();

  /* Cleanup on unload */
  window.addEventListener('beforeunload',function(){
    renderer.dispose();
    for(var i=0;i<particles.length;i++){
      particles[i].geometry.dispose();
      particles[i].material.dispose();
    }
    ringGeo.dispose();ringMat.dispose();
  });
})();

/* ═══════ HERO THREE.JS PARTICLES ═══════ */
(function(){
  var hcanvas=document.getElementById('heroCanvas');
  if(!hcanvas||typeof THREE==='undefined')return;

  var w=hcanvas.parentElement.offsetWidth,h=hcanvas.parentElement.offsetHeight;
  var renderer=new THREE.WebGLRenderer({canvas:hcanvas,alpha:true,antialias:false});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,1.5));
  renderer.setSize(w,h);

  var scene=new THREE.Scene();
  var camera=new THREE.PerspectiveCamera(50,w/h,.1,500);
  camera.position.z=20;

  var isMobile=window.innerWidth<768;
  var count=isMobile?30:80;
  var dots=[];

  for(var i=0;i<count;i++){
    var geo=new THREE.SphereGeometry(Math.random()*.08+.02,6,6);
    var mat=new THREE.MeshBasicMaterial({color:0x0D9488,transparent:true,opacity:Math.random()*.5+.1});
    var m=new THREE.Mesh(geo,mat);
    m.position.set((Math.random()-.5)*30,(Math.random()-.5)*20,(Math.random()-.5)*15);
    m.userData={speed:Math.random()*.005+.002,angle:Math.random()*Math.PI*2};
    scene.add(m);
    dots.push(m);
  }

  /* Connecting lines */
  var lineMat=new THREE.LineBasicMaterial({color:0x0D9488,transparent:true,opacity:.04});
  var lineGeoArr=[];
  for(var i=0;i<Math.min(20,count);i++){
    var j=(i+1)%count;
    var geo2=new THREE.BufferGeometry().setFromPoints([dots[i].position,dots[j].position]);
    var line=new THREE.Line(geo2,lineMat);
    scene.add(line);
    lineGeoArr.push({line:line,a:i,b:j});
  }

  var time=0;
  function tick(){
    requestAnimationFrame(tick);
    time+=.01;
    for(var i=0;i<dots.length;i++){
      var d=dots[i];
      d.position.y+=Math.sin(time+d.userData.angle)*d.userData.speed;
      d.position.x+=Math.cos(time*0.7+d.userData.angle)*d.userData.speed*.5;
    }
    /* Update connecting lines */
    for(var i=0;i<lineGeoArr.length;i++){
      var l=lineGeoArr[i];
      l.line.geometry.setFromPoints([dots[l.a].position.clone(),dots[l.b].position.clone()]);
    }
    renderer.render(scene,camera);
  }
  tick();

  window.addEventListener('resize',function(){
    w=hcanvas.parentElement.offsetWidth;h=hcanvas.parentElement.offsetHeight;
    camera.aspect=w/h;camera.updateProjectionMatrix();
    renderer.setSize(w,h);
  });

  window.addEventListener('beforeunload',function(){
    renderer.dispose();
    dots.forEach(function(d){d.geometry.dispose();d.material.dispose()});
    lineMat.dispose();
  });
})();

/* ═══════ GSAP ANIMATIONS ═══════ */
gsap.registerPlugin(ScrollTrigger);

/* Hero entrance timeline */
var heroTL=gsap.timeline({delay:.3});
heroTL
  .to('.hero-tag',{y:0,opacity:1,duration:.6,ease:'power3.out'},0)
  .to('#heroTitle .line-in',{y:'0%',duration:1,ease:'power3.out',stagger:.12},.15)
  .to('.hero-desc span',{y:'0%',duration:.7,ease:'power3.out'},.5)
  .to('.hero-actions > div',{y:'0%',duration:.6,ease:'power3.out',stagger:.1},.7)
  .to('#heroScroll',{opacity:1,duration:.5},.9);

/* Hero tag initial state */
gsap.set('.hero-tag',{y:30,opacity:0});

/* Hero parallax */
var heroImg=document.querySelector('#heroImg');
if(heroImg&&heroImg.tagName==='IMG'){
  gsap.to('#heroImg',{yPercent:20,ease:'none',scrollTrigger:{trigger:'#heroSec',start:'top top',end:'bottom top',scrub:true}});
}

/* Hero text fadeout */
gsap.to('.hero-content',{opacity:0,y:-60,ease:'none',scrollTrigger:{trigger:'#heroSec',start:'30% top',end:'70% top',scrub:true}});

/* Gallery items reveal */
gsap.utils.toArray('.gal-item').forEach(function(el,i){
  gsap.from(el,{y:60,opacity:0,duration:.8,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 90%',toggleActions:'play none none none'},delay:i*.08});
});

/* Stats counter */
document.querySelectorAll('.stat-num[data-count]').forEach(function(el){
  var target=parseInt(el.getAttribute('data-count'),10);
  if(isNaN(target))return;
  var suffix=target>10?'+':'';
  ScrollTrigger.create({trigger:el,start:'top 85%',once:true,onEnter:function(){
    gsap.to(el,{duration:2,ease:'power2.out',innerText:target,snap:{innerText:1},onUpdate:function(){
      el.textContent=Math.round(parseFloat(el.textContent))+suffix;
    }});
  }});
});

/* Service cards stagger */
gsap.utils.toArray('.svc-card').forEach(function(el,i){
  gsap.from(el,{y:50,opacity:0,duration:.7,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'},delay:i*.06});
});

/* Review cards stagger */
gsap.utils.toArray('#revGrid .rev-card').forEach(function(el,i){
  gsap.from(el,{y:60,opacity:0,duration:.8,ease:'power3.out',scrollTrigger:{trigger:'#revGrid',start:'top 85%',toggleActions:'play none none none'},delay:i*.1});
});

/* General section reveals */
gsap.utils.toArray('.sec-tag,.sec-title,.sec-sub,.about-grid,.about-quote,.info-grid,.c-stack,.hrs-table,.gm-btn,.cta-content,.rev-header,.rev-badge,.gal-single,.cat-tags,.wh-text').forEach(function(el){
  gsap.from(el,{y:40,opacity:0,duration:.8,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}});
});
</script>
</body>
</html>
