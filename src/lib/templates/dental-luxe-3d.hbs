      </div>
      {{#if (not_null rating)}}
      <div class="rev-badge">
        <div class="rev-badge-score">{{rating}}</div>
        <div class="rev-badge-info">
          <div class="rev-stars">
            {{#repeat 5}}<svg viewBox="0 0 20 20"><polygon points="10,1.5 12.39,7.36 18.81,7.64 13.76,11.82 15.53,18.08 10,14.27 4.47,18.08 6.24,11.82 1.19,7.64 7.61,7.36" fill="{{star_fill ../rating num}}"/></svg>{{/repeat}}
          </div>
          <div class="rev-badge-ct">{{review_count}} შეფასება · Google</div>
        </div>
      </div>
      {{/if}}
    </div>

    <div class="rev-grid" id="revGrid">
      {{#if (gt (len reviews) 0)}}
        {{#each (limit reviews 6)}}
