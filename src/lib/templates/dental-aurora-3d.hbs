<!DOCTYPE html>
<html lang="ka">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="referrer" content="no-referrer">
<title>{{default company_name "სტომატოლოგიური კლინიკა"}} — {{default category "სტომატოლოგია"}}</title>
<meta name="description" content="{{default description "თანამედროვე სტომატოლოგიური კლინიკა — პროფესიონალური მომსახურება, უახლესი ტექნოლოგიები, კომფორტული გარემო"}}">
{{#if (gt (len images) 0)}}<meta property="og:image" content="{{images.[0]}}">{{/if}}
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Dentist","name":"{{default company_name "სტომატოლოგიური კლინიკა"}}"{{#if address}},"address":{"@type":"PostalAddress","streetAddress":"{{address}}"}{{/if}}{{#if phone}},"telephone":"{{phone}}"{{/if}}{{#if website}},"url":"{{website}}"{{/if}}{{#if (not_null rating)}},"aggregateRating":{"@type":"AggregateRating","ratingValue":{{rating}},"reviewCount":{{review_count}} }{{/if}},"description":"{{default description "სტომატოლოგიური კლინიკა"}}"}</script>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&family=Noto+Sans+Georgian:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.7/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.7/ScrollTrigger.min.js"></script>
<style>
/* ═══════════════ RESET & BASE ═══════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:'DM Sans','Noto Sans Georgian',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button{background:none;border:none;color:inherit;cursor:pointer;font:inherit}
ul,ol{list-style:none}
h1,h2,h3,h4{font-family:'Sora','Noto Sans Georgian',sans-serif;font-weight:700;line-height:1.15;letter-spacing:-0.02em}

/* ═══════════════ VARIABLES ═══════════════ */
:root{
  --bg:#050510;
  --bg-2:#0c0c1d;
  --bg-3:#12122a;
  --surface:#161630;
  --surface-2:#1e1e40;
  --border:rgba(255,255,255,.06);
  --border-2:rgba(255,255,255,.1);
  --text:#eeeef5;
  --text-2:#a0a0b8;
  --text-3:#6b6b85;
  --primary:#00e5ff;
  --primary-glow:rgba(0,229,255,.15);
  --secondary:#7c3aed;
  --secondary-glow:rgba(124,58,237,.15);
  --accent:#ff6b6b;
  --accent-glow:rgba(255,107,107,.12);
  --gold:#ffd700;
  --heading:'Sora','Noto Sans Georgian',sans-serif;
  --body:'DM Sans','Noto Sans Georgian',sans-serif;
  --radius:16px;
  --radius-sm:10px;
  --radius-lg:24px;
  --ease:cubic-bezier(.16,1,.3,1);
}
.container{max-width:1200px;margin:0 auto;padding:0 2rem}
.section-tag{display:inline-block;font-family:var(--heading);font-size:.8rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--primary);margin-bottom:1rem;position:relative;padding-left:2rem}
.section-tag::before{content:'';position:absolute;left:0;top:50%;width:1.2rem;height:2px;background:var(--primary)}
.section-title{font-size:clamp(2rem,5vw,3.5rem);margin-bottom:1.5rem}
.gradient-text{background:linear-gradient(135deg,var(--text) 0%,var(--primary) 50%,var(--secondary) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* ═══════════════ SCROLL PROGRESS ═══════════════ */
.scroll-prog{position:fixed;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--primary),var(--secondary),var(--accent));z-index:10001;transform-origin:left;transform:scaleX(0);pointer-events:none}

/* ═══════════════ CURSOR GLOW ═══════════════ */
.cursor-glow{position:fixed;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(0,229,255,.05) 0%,transparent 70%);pointer-events:none;z-index:1;transform:translate(-50%,-50%);display:none}
@media(hover:hover){.cursor-glow{display:block}}

/* ═══════════════ THREE.JS CANVAS ═══════════════ */
.three-bg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}

/* ═══════════════ CONTENT WRAPPER ═══════════════ */
.wrap{position:relative;z-index:2}

/* ═══════════════ NAVIGATION ═══════════════ */
.nav{position:fixed;top:0;left:0;right:0;z-index:9999;padding:0 2rem;height:72px;display:flex;align-items:center;justify-content:space-between;transition:all .4s var(--ease)}
.nav.scrolled{background:rgba(5,5,16,.88);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-brand{font-family:var(--heading);font-size:1.15rem;font-weight:700;color:var(--text);white-space:nowrap;max-width:200px;overflow:hidden;text-overflow:ellipsis}
.nav-menu{display:flex;align-items:center;gap:2rem}
.nav-menu a{font-size:.9rem;color:var(--text-2);transition:color .3s;position:relative}
.nav-menu a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--primary);transition:width .3s var(--ease)}
.nav-menu a:hover{color:var(--text)}
.nav-menu a:hover::after{width:100%}
.nav-cta{padding:.55rem 1.4rem;border:1px solid var(--primary);border-radius:100px;font-size:.85rem;font-weight:500;color:var(--primary);transition:all .3s;white-space:nowrap}
.nav-cta:hover{background:var(--primary);color:var(--bg)}
.ham{display:none;flex-direction:column;gap:5px;cursor:pointer;z-index:10000;position:relative;padding:4px}
.ham span{display:block;width:22px;height:2px;background:var(--text);border-radius:2px;transition:all .3s var(--ease)}
.ham.active span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.ham.active span:nth-child(2){opacity:0}
.ham.active span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

/* ═══════════════ HERO ═══════════════ */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:6rem 2rem 4rem;position:relative}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 40%,rgba(0,229,255,.07) 0%,transparent 55%),radial-gradient(ellipse at 70% 60%,rgba(124,58,237,.07) 0%,transparent 55%);pointer-events:none}
.hero-tag{display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1.2rem;border:1px solid var(--border-2);border-radius:100px;font-size:.8rem;color:var(--text-2);margin-bottom:2rem;backdrop-filter:blur(8px)}
.hero-tag .dot{width:6px;height:6px;border-radius:50%;background:var(--primary);animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
.hero-title{font-size:clamp(2.8rem,9vw,7.5rem);font-weight:800;line-height:1.05;letter-spacing:-0.03em;margin-bottom:1.5rem;max-width:900px}
.hero-title .char{display:inline-block;will-change:transform,opacity}
.hero-title .word-space{display:inline-block;width:.3em}
.hero-sub{font-size:clamp(1rem,2.5vw,1.3rem);color:var(--text-2);max-width:560px;margin-bottom:2.5rem;font-weight:300;line-height:1.7}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center}
.btn-primary{display:inline-flex;align-items:center;gap:.6rem;padding:.85rem 2rem;background:var(--primary);color:var(--bg);border-radius:100px;font-weight:600;font-size:.95rem;transition:all .3s var(--ease);box-shadow:0 0 30px var(--primary-glow)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 40px rgba(0,229,255,.3)}
.btn-outline{display:inline-flex;align-items:center;gap:.6rem;padding:.85rem 2rem;border:1px solid var(--border-2);border-radius:100px;font-weight:500;font-size:.95rem;color:var(--text);transition:all .3s var(--ease)}
.btn-outline:hover{border-color:var(--text-2);transform:translateY(-2px)}
.hero-rating{margin-top:3rem;display:flex;align-items:center;gap:.8rem;padding:.6rem 1.2rem;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:100px}
.hero-rating .stars{color:var(--gold);font-size:1rem;letter-spacing:2px}
.hero-rating .r-num{font-family:var(--heading);font-weight:700;font-size:1.1rem}
.hero-rating .r-count{font-size:.85rem;color:var(--text-3)}

/* ═══════════════ FONT CALIBRATION ═══════════════ */
.name-short .hero-title{font-size:clamp(3rem,11vw,8rem)}
.name-medium .hero-title{font-size:clamp(2.4rem,8vw,6rem)}
.name-long .hero-title{font-size:clamp(1.8rem,5.5vw,4.2rem)}
.name-xlong .hero-title{font-size:clamp(1.3rem,3.5vw,3rem)}

/* ═══════════════ MARQUEE ═══════════════ */
.marquee-sec{padding:1.2rem 0;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);overflow:hidden;position:relative}
.marquee-inner{display:flex;width:max-content;animation:marqueeSlide 35s linear infinite}
.marquee-content{display:flex;align-items:center;gap:3rem;padding:0 1.5rem;white-space:nowrap}
.marquee-content span{font-family:var(--heading);font-size:.85rem;font-weight:500;letter-spacing:.05em;color:var(--text-2)}
.marquee-content .mx-dot{color:var(--primary);font-size:1.2rem}
@keyframes marqueeSlide{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ═══════════════ ABOUT ═══════════════ */
.about{padding:clamp(5rem,12vw,10rem) 0}
.about-inner{display:grid;grid-template-columns:1.1fr .9fr;gap:4rem;align-items:center}
.about-heading{font-size:clamp(1.8rem,4.5vw,3rem);margin-bottom:1.5rem}
.about-desc{font-size:1.05rem;color:var(--text-2);line-height:1.8;margin-bottom:2rem;max-width:520px}
.about-badge{display:inline-flex;align-items:center;gap:1rem;padding:1rem 1.5rem;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:var(--radius);backdrop-filter:blur(12px)}
.badge-num{font-family:var(--heading);font-size:2.2rem;font-weight:800;color:var(--primary)}
.badge-info{display:flex;flex-direction:column;gap:.1rem}
.badge-stars{color:var(--gold);font-size:.9rem;letter-spacing:2px}
.badge-label{font-size:.8rem;color:var(--text-3)}
.about-visual{position:relative;border-radius:var(--radius-lg);overflow:hidden}
.about-img{width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:var(--radius-lg);border:1px solid var(--border)}
.about-gradient{width:100%;aspect-ratio:4/5;border-radius:var(--radius-lg);background:linear-gradient(135deg,var(--bg-3) 0%,var(--surface) 50%,var(--bg-2) 100%);position:relative;overflow:hidden;border:1px solid var(--border)}
.about-gradient::before{content:'';position:absolute;width:200%;height:200%;top:-50%;left:-50%;background:conic-gradient(from 0deg,transparent,var(--primary-glow),transparent,var(--secondary-glow),transparent);animation:gradSpin 10s linear infinite;opacity:.6}
@keyframes gradSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

/* ═══════════════ SERVICES — HORIZONTAL SCROLL ═══════════════ */
.svc-sec{padding:clamp(4rem,10vw,8rem) 0;overflow:hidden}
.svc-header{text-align:center;margin-bottom:3rem;padding:0 2rem}
.svc-header p{color:var(--text-2);font-size:1.05rem;max-width:520px;margin:0 auto}
.svc-track{display:flex;gap:1.5rem;padding:0 4vw;will-change:transform}
.svc-card{flex:0 0 370px;min-height:420px;border-radius:var(--radius-lg);background:var(--surface);border:1px solid var(--border);padding:2.5rem;display:flex;flex-direction:column;transition:all .45s var(--ease);position:relative;overflow:hidden}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--primary),var(--secondary));opacity:0;transition:opacity .4s}
.svc-card:hover{border-color:rgba(0,229,255,.25);transform:translateY(-6px);box-shadow:0 24px 60px rgba(0,229,255,.08)}
.svc-card:hover::before{opacity:1}
.svc-num{font-family:var(--heading);font-size:3.5rem;font-weight:800;background:linear-gradient(135deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;opacity:.15;margin-bottom:1rem;line-height:1}
.svc-card h3{font-size:1.3rem;margin-bottom:.8rem}
.svc-card p{color:var(--text-2);font-size:.95rem;line-height:1.7;flex:1}
.svc-card .svc-arrow{display:flex;align-items:center;gap:.5rem;color:var(--primary);font-size:.85rem;font-weight:500;margin-top:1.5rem;opacity:0;transform:translateX(-8px);transition:all .3s var(--ease)}
.svc-card:hover .svc-arrow{opacity:1;transform:translateX(0)}

/* ═══════════════ STATS ═══════════════ */
.stats-sec{padding:clamp(4rem,10vw,7rem) 0;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center}
.stat-item{padding:2rem 1rem}
.stat-row{display:flex;align-items:baseline;justify-content:center;gap:.2rem}
.stat-num{font-family:var(--heading);font-size:clamp(2.5rem,7vw,4.5rem);font-weight:800;background:linear-gradient(135deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.stat-suffix{font-family:var(--heading);font-size:clamp(1.5rem,4vw,2.5rem);font-weight:700;color:var(--primary)}
.stat-label{display:block;margin-top:.6rem;font-size:.9rem;color:var(--text-3);font-weight:400}

/* ═══════════════ GALLERY ═══════════════ */
.gallery-sec{padding:clamp(5rem,12vw,10rem) 0}
.gal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:3rem}
.gal-grid.single{grid-template-columns:1fr;max-width:600px;margin-left:auto;margin-right:auto}
.gal-grid.duo{grid-template-columns:repeat(2,1fr)}
.gal-item{position:relative;overflow:hidden;border-radius:var(--radius);aspect-ratio:4/3;cursor:pointer}
.gal-item img{width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease)}
.gal-item::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(5,5,16,.6) 0%,transparent 50%);opacity:0;transition:opacity .4s}
.gal-item:hover img{transform:scale(1.08)}
.gal-item:hover::after{opacity:1}

/* ═══════════════ REVIEWS ═══════════════ */
.rev-sec{padding:clamp(5rem,12vw,10rem) 0;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.rev-header{text-align:center;margin-bottom:3rem}
.rev-header p{color:var(--text-2);max-width:420px;margin:.5rem auto 0}
.rev-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1.5rem}
.rev-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;transition:all .4s var(--ease);position:relative}
.rev-card:hover{border-color:rgba(0,229,255,.15);transform:translateY(-3px)}
.rev-stars{color:var(--gold);font-size:.95rem;letter-spacing:2px;margin-bottom:1rem}
.rev-text{font-size:.95rem;color:var(--text-2);line-height:1.7;margin-bottom:1.5rem;font-style:italic}
.rev-author{display:flex;align-items:center;gap:.8rem}
.rev-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));display:flex;align-items:center;justify-content:center;font-family:var(--heading);font-weight:700;font-size:.9rem;color:var(--bg);flex-shrink:0}
.rev-name{font-weight:600;font-size:.9rem}
.rev-date{font-size:.8rem;color:var(--text-3)}

/* ═══════════════ PROCESS ═══════════════ */
.process-sec{padding:clamp(5rem,12vw,10rem) 0}
.process-header{text-align:center;margin-bottom:4rem}
.process-header p{color:var(--text-2);max-width:480px;margin:.5rem auto 0}
.process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;position:relative}
.process-step{text-align:center;position:relative;padding-top:4rem}
.step-dot{width:18px;height:18px;border-radius:50%;background:var(--primary);position:absolute;top:0;left:50%;transform:translateX(-50%);z-index:2;box-shadow:0 0 24px var(--primary-glow),0 0 48px rgba(0,229,255,.08)}
.step-line{position:absolute;top:8px;left:calc(50% + 12px);width:calc(100% - 24px);height:2px;background:var(--border-2)}
.process-step:last-child .step-line{display:none}
.step-num{font-family:var(--heading);font-size:3rem;font-weight:800;background:linear-gradient(135deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;opacity:.15;margin-bottom:.5rem;line-height:1}
.process-step h3{font-size:1.15rem;margin-bottom:.5rem}
.process-step p{font-size:.9rem;color:var(--text-2);line-height:1.6;max-width:220px;margin:0 auto}

/* ═══════════════ FAQ ═══════════════ */
.faq-sec{padding:clamp(5rem,12vw,10rem) 0;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.faq-header{text-align:center;margin-bottom:3rem}
.faq-list{max-width:780px;margin:0 auto;display:flex;flex-direction:column;gap:.8rem}
.faq-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:border-color .3s}
.faq-item:hover,.faq-item.open{border-color:rgba(0,229,255,.15)}
.faq-q{width:100%;display:flex;align-items:center;justify-content:space-between;padding:1.3rem 1.5rem;font-size:1rem;font-weight:500;text-align:left;gap:1rem;cursor:pointer}
.faq-chevron{width:20px;height:20px;flex-shrink:0;transition:transform .4s var(--ease);color:var(--text-3)}
.faq-item.open .faq-chevron{transform:rotate(180deg);color:var(--primary)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .5s var(--ease)}
.faq-a-inner{padding:0 1.5rem 1.3rem;color:var(--text-2);font-size:.95rem;line-height:1.7}

/* ═══════════════ CONTACT ═══════════════ */
.contact-sec{padding:clamp(5rem,12vw,10rem) 0}
.contact-header{text-align:center;margin-bottom:3rem}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.contact-info{display:flex;flex-direction:column;gap:1rem}
.contact-card{display:flex;align-items:center;gap:1rem;padding:1.2rem 1.5rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);transition:all .3s var(--ease)}
.contact-card:hover{border-color:rgba(0,229,255,.2);transform:translateX(4px)}
.cc-icon{width:44px;height:44px;border-radius:12px;background:var(--primary-glow);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cc-icon svg{width:20px;height:20px;stroke:var(--primary);fill:none;stroke-width:2}
.cc-label{font-size:.8rem;color:var(--text-3);display:block}
.cc-value{font-weight:500;font-size:.95rem}
.hours-block{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-top:.5rem}
.hours-block h3{font-size:1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
.hours-row{display:flex;justify-content:space-between;padding:.45rem 0;border-bottom:1px solid var(--border);font-size:.9rem}
.hours-row:last-child{border-bottom:none}
.hours-row span:first-child{color:var(--text-2)}
.hours-row span:last-child{font-weight:500}
.social-row{display:flex;gap:.8rem;margin-top:.5rem}
.social-row a{display:flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:12px;background:var(--surface);border:1px solid var(--border);font-size:.8rem;font-weight:700;color:var(--text-3);transition:all .3s}
.social-row a:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-glow)}
.contact-map{border-radius:var(--radius-lg);overflow:hidden;min-height:400px;border:1px solid var(--border)}
.contact-map iframe{width:100%;height:100%;min-height:400px;display:block}
.map-placeholder{width:100%;min-height:400px;background:var(--surface);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;font-size:1rem;color:var(--text-3)}
.map-placeholder span{font-size:3rem}

/* ═══════════════ CTA BANNER ═══════════════ */
.cta-sec{padding:clamp(5rem,12vw,8rem) 2rem;background:linear-gradient(135deg,rgba(0,229,255,.06) 0%,rgba(124,58,237,.08) 50%,rgba(255,107,107,.05) 100%);text-align:center;position:relative;overflow:hidden}
.cta-sec::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:conic-gradient(from 180deg,transparent 60%,var(--primary-glow) 70%,transparent 80%);animation:ctaSpin 12s linear infinite;opacity:.3}
@keyframes ctaSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.cta-inner{position:relative;z-index:2;max-width:650px;margin:0 auto}
.cta-inner h2{font-size:clamp(2rem,5vw,3.2rem);margin-bottom:1rem}
.cta-inner p{color:var(--text-2);font-size:1.1rem;margin-bottom:2.5rem}
.cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-cta-lg{display:inline-flex;align-items:center;gap:.6rem;padding:1rem 2.5rem;background:var(--primary);color:var(--bg);border-radius:100px;font-weight:700;font-size:1rem;transition:all .3s var(--ease);box-shadow:0 0 30px var(--primary-glow);animation:ctaPulse 3s ease infinite}
@keyframes ctaPulse{0%,100%{box-shadow:0 0 30px var(--primary-glow)}50%{box-shadow:0 0 50px rgba(0,229,255,.25)}}
.btn-cta-lg:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 12px 50px rgba(0,229,255,.3)}
.btn-cta-ghost{display:inline-flex;align-items:center;gap:.6rem;padding:1rem 2.5rem;border:1px solid var(--border-2);border-radius:100px;font-weight:500;font-size:1rem;color:var(--text);transition:all .3s var(--ease)}
.btn-cta-ghost:hover{border-color:var(--text-2);transform:translateY(-3px)}

/* ═══════════════ FOOTER ═══════════════ */
.footer-sec{padding:4rem 0 2rem;border-top:1px solid var(--border)}
.footer-top{display:flex;justify-content:space-between;align-items:start;gap:2rem;margin-bottom:3rem}
.footer-name{font-family:var(--heading);font-weight:700;font-size:1.2rem;display:block;margin-bottom:.3rem}
.footer-cat{font-size:.85rem;color:var(--text-3)}
.footer-links{display:flex;gap:1.5rem;flex-wrap:wrap}
.footer-links a{font-size:.9rem;color:var(--text-3);transition:color .3s}
.footer-links a:hover{color:var(--primary)}
.footer-bottom{padding-top:2rem;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.footer-bottom span{font-size:.8rem;color:var(--text-3)}

/* ═══════════════ FLOATING PHONE ═══════════════ */
.float-phone{position:fixed;bottom:2rem;right:2rem;z-index:9998;width:56px;height:56px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,229,255,.3);transition:all .3s var(--ease);animation:floatBob 3s ease-in-out infinite}
.float-phone:hover{transform:scale(1.1);box-shadow:0 8px 30px rgba(0,229,255,.4)}
.float-phone svg{width:24px;height:24px;stroke:#050510;fill:none;stroke-width:2}
@keyframes floatBob{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}

/* ═══════════════ REVEAL ANIMATION PREP ═══════════════ */
.reveal-el{opacity:0;transform:translateY(40px)}

/* ═══════════════ RESPONSIVE — TABLET ═══════════════ */
@media(max-width:1024px){
  .about-inner{grid-template-columns:1fr;gap:3rem}
  .about-visual{max-width:500px;margin:0 auto}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .gal-grid{grid-template-columns:repeat(2,1fr)}
  .process-grid{grid-template-columns:repeat(2,1fr);gap:2rem 1.5rem}
  .process-step:nth-child(2) .step-line{display:none}
  .contact-grid{grid-template-columns:1fr}
  .contact-map{min-height:320px}
  .contact-map iframe{min-height:320px}
}

/* ═══════════════ RESPONSIVE — MOBILE ═══════════════ */
@media(max-width:768px){
  .nav-menu{position:fixed;inset:0;flex-direction:column;justify-content:center;background:rgba(5,5,16,.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);opacity:0;pointer-events:none;transition:opacity .4s var(--ease);z-index:9998;gap:2.5rem}
  .nav-menu.open{opacity:1;pointer-events:all}
  .nav-menu a{font-size:1.4rem;color:var(--text)}
  .nav-menu a::after{display:none}
  .nav-cta{font-size:1rem;padding:.7rem 2rem}
  .ham{display:flex}
  .hero{min-height:100svh;padding:5rem 1.5rem 3rem}
  .hero-sub{font-size:1rem}
  .hero-actions{flex-direction:column;width:100%;max-width:320px}
  .btn-primary,.btn-outline{justify-content:center;width:100%}
  .name-short .hero-title{font-size:clamp(2.4rem,9vw,4rem)}
  .name-medium .hero-title{font-size:clamp(2rem,7vw,3.2rem)}
  .name-long .hero-title{font-size:clamp(1.5rem,5vw,2.4rem)}
  .name-xlong .hero-title{font-size:clamp(1.2rem,3.5vw,1.8rem)}
  .svc-track{flex-direction:column;padding:0 1.5rem}
  .svc-card{flex:none;width:100%;min-height:auto}
  .stats-grid{grid-template-columns:repeat(2,1fr);gap:1rem}
  .gal-grid{grid-template-columns:1fr}
  .rev-grid{grid-template-columns:1fr}
  .process-grid{grid-template-columns:1fr;gap:2rem}
  .step-line{display:none}
  .process-step{padding-top:0;padding-left:3.5rem;text-align:left}
  .step-dot{left:0;top:4px;transform:none}
  .process-step p{margin:0}
  .contact-grid{grid-template-columns:1fr}
  .footer-top{flex-direction:column;gap:1.5rem}
  .footer-links{flex-direction:column;gap:.8rem}
  .float-phone{bottom:1.2rem;right:1.2rem;width:50px;height:50px}
  .container{padding:0 1.5rem}
}

/* ═══════════════ RESPONSIVE — SMALL ═══════════════ */
@media(max-width:420px){
  .hero{padding:4rem 1rem 2.5rem}
  .hero-tag{font-size:.7rem;padding:.4rem 1rem}
  .stats-grid{grid-template-columns:1fr}
  .faq-q{font-size:.9rem;padding:1.1rem 1.2rem}
  .faq-a-inner{padding:0 1.2rem 1.1rem;font-size:.9rem}
  .rev-card{padding:1.5rem}
  .svc-card{padding:2rem}
}
</style>
</head>
<body>

<!-- Scroll Progress -->
<div class="scroll-prog" aria-hidden="true"></div>

<!-- Cursor Glow -->
<div class="cursor-glow" aria-hidden="true"></div>

<!-- Three.js 3D Canvas -->
<canvas class="three-bg" id="threeBg"></canvas>

<!-- Content -->
<div class="wrap">

<!-- ════════ NAV ════════ -->
<nav class="nav" id="mainNav">
  <a href="#heroSec" class="nav-brand">{{default company_name "სტომატოლოგიური კლინიკა"}}</a>
  <div class="nav-menu" id="navMenu">
    <a href="#aboutSec">ჩვენ შესახებ</a>
    <a href="#svcSec">სერვისები</a>
    {{#if (gt review_count 0)}}<a href="#revSec">შეფასებები</a>{{/if}}
    <a href="#contactSec">კონტაქტი</a>
    {{#if phone}}<a href="tel:{{phone}}" class="nav-cta">დარეკეთ</a>{{/if}}
  </div>
  <button class="ham" id="hamBtn" aria-label="მენიუ"><span></span><span></span><span></span></button>
</nav>

<!-- ════════ HERO ════════ -->
<section class="hero {{company_name_class}}" id="heroSec">
  <div class="hero-tag reveal-el"><span class="dot"></span> {{default category "სტომატოლოგია"}}</div>
  <h1 class="hero-title gradient-text" id="heroTitle">{{default company_name "სტომატოლოგიური კლინიკა"}}</h1>
  <p class="hero-sub reveal-el">{{default description "თანამედროვე სტომატოლოგიური კლინიკა — პროფესიონალური მომსახურება, უახლესი ტექნოლოგიები და კომფორტული გარემო თქვენი ჯანსაღი ღიმილისთვის"}}</p>
  <div class="hero-actions reveal-el">
    {{#if phone}}
    <a href="tel:{{phone}}" class="btn-primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {{phone_display}}
    </a>
    {{/if}}
    {{#if booking_link}}
    <a href="{{booking_link}}" target="_blank" class="btn-outline">ონლაინ ჯავშანი →</a>
    {{else}}
    {{#if phone}}
    <a href="#contactSec" class="btn-outline">კონტაქტი →</a>
    {{/if}}
    {{/if}}
  </div>
  {{#if (not_null rating)}}
  <div class="hero-rating reveal-el">
    <span class="r-num">{{rating}}</span>
    <span class="stars">{{#repeat (math_floor rating)}}★{{/repeat}}</span>
    {{#if (gt review_count 0)}}<span class="r-count">{{review_count}} შეფასება</span>{{/if}}
  </div>
  {{/if}}
</section>

<!-- ════════ MARQUEE TRUST STRIP ════════ -->
<div class="marquee-sec">
  <div class="marquee-inner">
    <div class="marquee-content">
      <span class="mx-dot">◆</span><span>თანამედროვე აღჭურვილობა</span>
      <span class="mx-dot">◆</span><span>გამოცდილი სპეციალისტები</span>
      <span class="mx-dot">◆</span><span>უმტკივნეულო პროცედურები</span>
      <span class="mx-dot">◆</span><span>ინდივიდუალური მიდგომა</span>
      <span class="mx-dot">◆</span><span>უფასო კონსულტაცია</span>
      <span class="mx-dot">◆</span><span>მოქნილი განვადება</span>
    </div>
    <div class="marquee-content" aria-hidden="true">
      <span class="mx-dot">◆</span><span>თანამედროვე აღჭურვილობა</span>
      <span class="mx-dot">◆</span><span>გამოცდილი სპეციალისტები</span>
      <span class="mx-dot">◆</span><span>უმტკივნეულო პროცედურები</span>
      <span class="mx-dot">◆</span><span>ინდივიდუალური მიდგომა</span>
      <span class="mx-dot">◆</span><span>უფასო კონსულტაცია</span>
      <span class="mx-dot">◆</span><span>მოქნილი განვადება</span>
    </div>
  </div>
</div>

<!-- ════════ ABOUT ════════ -->
<section class="about" id="aboutSec">
  <div class="container about-inner">
    <div class="about-text">
      <span class="section-tag reveal-el">ჩვენ შესახებ</span>
      <h2 class="about-heading reveal-el">ჩვენ ვქმნით ღიმილებს,<br>რომლებიც ცხოვრებას ცვლის</h2>
      <p class="about-desc reveal-el">{{default description "ჩვენი კლინიკა აერთიანებს თანამედროვე ტექნოლოგიებს, გამოცდილ სპეციალისტებს და ინდივიდუალურ მიდგომას. ყოველი პაციენტი ჩვენთვის უნიკალურია — სწორედ ამიტომ ვაქცევთ ყოველ ვიზიტს კომფორტულ და სასიამოვნო გამოცდილებად. ჩვენი მიზანია თქვენი ჯანმრთელი და ლამაზი ღიმილი."}}</p>
      {{#if (not_null rating)}}
      <div class="about-badge reveal-el">
        <div class="badge-num">{{rating}}</div>
        <div class="badge-info">
          <div class="badge-stars">{{#repeat (math_floor rating)}}★{{/repeat}}{{#repeat (subtract 5 (math_floor rating))}}☆{{/repeat}}</div>
          <span class="badge-label">Google-ის რეიტინგი{{#if (gt review_count 0)}} · {{review_count}} შეფასება{{/if}}</span>
        </div>
      </div>
      {{/if}}
    </div>
    <div class="about-visual reveal-el">
      {{#if (gt (len images) 0)}}
      <img src="{{images.[0]}}" alt="{{company_name}}" class="about-img" loading="lazy">
      {{else}}
      <div class="about-gradient"></div>
      {{/if}}
    </div>
  </div>
</section>

<!-- ════════ SERVICES — HORIZONTAL SCROLL ════════ -->
<section class="svc-sec" id="svcSec">
  <div class="svc-header">
    <span class="section-tag reveal-el">სერვისები</span>
    <h2 class="section-title reveal-el">რას გთავაზობთ</h2>
    <p class="reveal-el">პროფესიონალური სტომატოლოგიური მომსახურება თანამედროვე ტექნოლოგიებით</p>
  </div>
  <div class="svc-track" id="svcTrack">
    <div class="svc-card">
      <div class="svc-num">01</div>
      <h3>იმპლანტაცია</h3>
      <p>თანამედროვე იმპლანტების ჩანერგვა მაღალი ხარისხის მასალებით. აღვადგენთ დაკარგული კბილების ფუნქციას და ესთეტიკას ბუნებრივი შედეგით.</p>
      <span class="svc-arrow">გაიგე მეტი →</span>
    </div>
    <div class="svc-card">
      <div class="svc-num">02</div>
      <h3>ესთეტიკური სტომატოლოგია</h3>
      <p>ვინირები, გათეთრება და კოსმეტიკური რესტავრაცია. შევქმნით სრულყოფილ ღიმილს, რომელიც თავდაჯერებულობას მოგმატებთ.</p>
      <span class="svc-arrow">გაიგე მეტი →</span>
    </div>
    <div class="svc-card">
      <div class="svc-num">03</div>
      <h3>ორთოდონტია</h3>
      <p>ბრეკეტ-სისტემები და გამჭვირვალე ალაინერები კბილების სწორი განლაგებისთვის. თანამედროვე მიდგომა ყველა ასაკის პაციენტისთვის.</p>
      <span class="svc-arrow">გაიგე მეტი →</span>
    </div>
    <div class="svc-card">
      <div class="svc-num">04</div>
      <h3>ბავშვთა სტომატოლოგია</h3>
      <p>მეგობრული გარემო და ნაზი მიდგომა პატარა პაციენტებისთვის. ჯანსაღი ღიმილის საფუძველი ბავშვობიდან იწყება.</p>
      <span class="svc-arrow">გაიგე მეტი →</span>
    </div>
    <div class="svc-card">
      <div class="svc-num">05</div>
      <h3>ქირურგიული სტომატოლოგია</h3>
      <p>ამოღება, ძვლის აუგმენტაცია და ყბა-სახის ქირურგია. რთული შემთხვევების გადაწყვეტა მინიმალ-ინვაზიური მეთოდებით.</p>
      <span class="svc-arrow">გაიგე მეტი →</span>
    </div>
    <div class="svc-card">
      <div class="svc-num">06</div>
      <h3>პროფილაქტიკა და ჰიგიენა</h3>
      <p>პროფესიონალური წმენდა, ფტორირება და პერიოდული გამოკვლევა. პრევენცია საუკეთესო მკურნალობაა — დაიცავით ღიმილი დროულად.</p>
      <span class="svc-arrow">გაიგე მეტი →</span>
    </div>
  </div>
</section>

<!-- ════════ STATS ════════ -->
<section class="stats-sec">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item reveal-el">
        <div class="stat-row"><span class="stat-num" data-count="5000">0</span><span class="stat-suffix">+</span></div>
        <span class="stat-label">კმაყოფილი პაციენტი</span>
      </div>
      <div class="stat-item reveal-el">
        <div class="stat-row"><span class="stat-num" data-count="15">0</span><span class="stat-suffix">+</span></div>
        <span class="stat-label">წლიანი გამოცდილება</span>
      </div>
      <div class="stat-item reveal-el">
        <div class="stat-row"><span class="stat-num" data-count="98">0</span><span class="stat-suffix">%</span></div>
        <span class="stat-label">კმაყოფილების მაჩვენებელი</span>
      </div>
      <div class="stat-item reveal-el">
        <div class="stat-row"><span class="stat-num" data-count="12000">0</span><span class="stat-suffix">+</span></div>
        <span class="stat-label">წარმატებული პროცედურა</span>
      </div>
    </div>
  </div>
</section>

<!-- ════════ GALLERY ════════ -->
{{#if (gt (len images) 1)}}
<section class="gallery-sec" id="galSec">
  <div class="container">
    <span class="section-tag reveal-el">გალერეა</span>
    <h2 class="section-title reveal-el">ჩვენი კლინიკა</h2>
    <div class="gal-grid{{#if (eq (len images) 2)}} duo{{/if}}">
      {{#each (limit images 6)}}
      <div class="gal-item reveal-el">
        <img src="{{this}}" alt="კლინიკის ფოტო" loading="lazy">
      </div>
      {{/each}}
    </div>
  </div>
</section>
{{/if}}

<!-- ════════ REVIEWS ════════ -->
<section class="rev-sec" id="revSec">
  <div class="container">
    <div class="rev-header">
      <span class="section-tag reveal-el">შეფასებები</span>
      <h2 class="section-title reveal-el">რას ამბობენ ჩვენი პაციენტები</h2>
      {{#if (not_null rating)}}<p class="reveal-el">საშუალო რეიტინგი: <strong>{{rating}}</strong> / 5</p>{{/if}}
    </div>
    <div class="rev-grid">
      {{#if (gt review_count 0)}}
        {{#each (limit reviews 6)}}
        <div class="rev-card reveal-el">
          <div class="rev-stars">{{#repeat (math_floor this.rating)}}★{{/repeat}}{{#repeat (subtract 5 (math_floor this.rating))}}☆{{/repeat}}</div>
          <p class="rev-text">"{{truncate this.text 200}}"</p>
          <div class="rev-author">
            <div class="rev-avatar">{{initial this.author}}</div>
            <div>
              <div class="rev-name">{{this.author}}</div>
              {{#if this.date}}<div class="rev-date">{{this.date}}</div>{{/if}}
            </div>
          </div>
        </div>
        {{/each}}
      {{else}}
        {{#if (gt (len review_snippets) 0)}}
          {{#each (limit review_snippets 4)}}
          <div class="rev-card reveal-el">
            <div class="rev-stars">★★★★★</div>
