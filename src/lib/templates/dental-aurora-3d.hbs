<script>
(function(){
'use strict';

var isMobile = window.innerWidth < 768;

/* ═══════════════ THREE.JS — MORPHING AURORA MESH ═══════════════ */
(function initThree(){
  if(typeof THREE==='undefined')return;
  var canvas = document.getElementById('threeBg');
  if(!canvas)return;

  var W = window.innerWidth, H = window.innerHeight;
  var scene = new THREE.Scene();
  var camera = new THREE.PerspectiveCamera(55, W/H, 0.1, 100);
  camera.position.z = isMobile ? 4.5 : 3.8;

  var renderer = new THREE.WebGLRenderer({canvas:canvas, antialias:!isMobile, alpha:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);
  renderer.setClearColor(0x000000, 0);

  /* --- Shaders --- */
  var vertSrc = [
    'uniform float uTime;',
    'uniform float uMorph;',
    'varying vec3 vNorm;',
    'varying float vDisp;',
    '',
    '// Simplex 3D Noise — Ashima/Stefan Gustavson',
    'vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x,289.0);}',
    'vec4 taylorInvSqrt(vec4 r){return 1.79284291400159-0.85373472095314*r;}',
    'float snoise(vec3 v){',
    '  const vec2 C=vec2(1.0/6.0,1.0/3.0);',
    '  const vec4 D=vec4(0.0,0.5,1.0,2.0);',
    '  vec3 i=floor(v+dot(v,C.yyy));',
    '  vec3 x0=v-i+dot(i,C.xxx);',
    '  vec3 g=step(x0.yzx,x0.xyz);',
    '  vec3 l=1.0-g;',
    '  vec3 i1=min(g.xyz,l.zxy);',
    '  vec3 i2=max(g.xyz,l.zxy);',
    '  vec3 x1=x0-i1+C.xxx;',
    '  vec3 x2=x0-i2+C.yyy;',
    '  vec3 x3=x0-D.yyy;',
    '  i=mod(i,289.0);',
    '  vec4 p=permute(permute(permute(',
    '    i.z+vec4(0.0,i1.z,i2.z,1.0))',
    '    +i.y+vec4(0.0,i1.y,i2.y,1.0))',
    '    +i.x+vec4(0.0,i1.x,i2.x,1.0));',
    '  float n_=1.0/7.0;',
    '  vec3 ns=n_*D.wyz-D.xzx;',
    '  vec4 j=p-49.0*floor(p*ns.z*ns.z);',
    '  vec4 x_=floor(j*ns.z);',
    '  vec4 y_=floor(j-7.0*x_);',
    '  vec4 x=x_*ns.x+ns.yyyy;',
    '  vec4 y=y_*ns.x+ns.yyyy;',
    '  vec4 h=1.0-abs(x)-abs(y);',
    '  vec4 b0=vec4(x.xy,y.xy);',
    '  vec4 b1=vec4(x.zw,y.zw);',
    '  vec4 s0=floor(b0)*2.0+1.0;',
    '  vec4 s1=floor(b1)*2.0+1.0;',
    '  vec4 sh=-step(h,vec4(0.0));',
    '  vec4 a0=b0.xzyw+s0.xzyw*sh.xxyy;',
    '  vec4 a1=b1.xzyw+s1.xzyw*sh.zzww;',
    '  vec3 p0=vec3(a0.xy,h.x);',
    '  vec3 p1=vec3(a0.zw,h.y);',
    '  vec3 p2=vec3(a1.xy,h.z);',
    '  vec3 p3=vec3(a1.zw,h.w);',
    '  vec4 norm=taylorInvSqrt(vec4(dot(p0,p0),dot(p1,p1),dot(p2,p2),dot(p3,p3)));',
    '  p0*=norm.x;p1*=norm.y;p2*=norm.z;p3*=norm.w;',
    '  vec4 m=max(0.6-vec4(dot(x0,x0),dot(x1,x1),dot(x2,x2),dot(x3,x3)),0.0);',
    '  m=m*m;',
    '  return 42.0*dot(m*m,vec4(dot(p0,x0),dot(p1,x1),dot(p2,x2),dot(p3,x3)));',
    '}',
    '',
    'void main(){',
    '  float n=snoise(position*1.2+uTime*0.25)*uMorph;',
    '  n+=snoise(position*2.4+uTime*0.15)*uMorph*0.5;',
    '  vec3 newPos=position+normal*n;',
    '  vNorm=normalize(normalMatrix*normal);',
    '  vDisp=n;',
    '  gl_Position=projectionMatrix*modelViewMatrix*vec4(newPos,1.0);',
    '}'
  ].join('\n');

  var fragSrc = [
    'uniform vec3 uColorA;',
    'uniform vec3 uColorB;',
    'uniform vec3 uColorC;',
    'varying vec3 vNorm;',
    'varying float vDisp;',
    '',
    'void main(){',
    '  float t=smoothstep(-0.3,0.3,vDisp);',
    '  vec3 col=mix(uColorA,uColorB,t);',
    '  col=mix(col,uColorC,smoothstep(0.35,0.85,t));',
    '  float rim=1.0-abs(dot(vNorm,vec3(0.0,0.0,1.0)));',
    '  rim=pow(rim,2.5);',
    '  col+=uColorA*rim*0.5;',
    '  gl_FragColor=vec4(col,0.6+rim*0.3);',
    '}'
  ].join('\n');

  /* --- Mesh --- */
  var detail = isMobile ? 3 : 4;
  var geo = new THREE.IcosahedronGeometry(1.5, detail);
  var mat = new THREE.ShaderMaterial({
    uniforms:{
      uTime:{value:0},
      uMorph:{value:0.3},
      uColorA:{value:new THREE.Color('#00e5ff')},
      uColorB:{value:new THREE.Color('#7c3aed')},
      uColorC:{value:new THREE.Color('#ff6b6b')}
    },
    vertexShader:vertSrc,
    fragmentShader:fragSrc,
    transparent:true,
    side:THREE.DoubleSide,
    depthWrite:false
  });
  var mesh = new THREE.Mesh(geo, mat);
  scene.add(mesh);

  /* Wireframe overlay */
  var wireGeo = new THREE.IcosahedronGeometry(1.55, isMobile?2:3);
  var wireMat = new THREE.MeshBasicMaterial({color:0x00e5ff, wireframe:true, transparent:true, opacity:0.045, depthWrite:false});
  var wireMesh = new THREE.Mesh(wireGeo, wireMat);
  scene.add(wireMesh);

  /* --- Mouse & Scroll --- */
  var scrollY = 0, mouseX = 0, mouseY = 0;
  var targetRX = 0, targetRY = 0;
  window.addEventListener('scroll', function(){ scrollY = window.scrollY; }, {passive:true});
  if(!isMobile){
    document.addEventListener('mousemove', function(e){
      mouseX = (e.clientX/W - 0.5)*2;
      mouseY = (e.clientY/H - 0.5)*2;
    }, {passive:true});
  }

  /* --- Resize --- */
  window.addEventListener('resize', function(){
    W = window.innerWidth; H = window.innerHeight;
    camera.aspect = W/H;
    camera.updateProjectionMatrix();
    renderer.setSize(W, H);
  });

  /* --- Animate --- */
  function animate(){
    requestAnimationFrame(animate);
    var t = performance.now()*0.001;
    mat.uniforms.uTime.value = t;

    var baseRY = t*0.12 + scrollY*0.0003;
    var baseRX = Math.sin(t*0.08)*0.15;

    targetRY += (mouseX*0.3 - targetRY)*0.04;
    targetRX += (-mouseY*0.2 - targetRX)*0.04;

    mesh.rotation.y = baseRY + targetRY;
    mesh.rotation.x = baseRX + targetRX;
    wireMesh.rotation.copy(mesh.rotation);

    renderer.render(scene, camera);
  }
  animate();

  /* Fade canvas after hero */
  if(typeof gsap!=='undefined'){
    gsap.to(canvas,{opacity:0.12, scrollTrigger:{trigger:'.hero',start:'bottom center',end:'bottom top',scrub:true}});
  }
})();

/* ═══════════════ GSAP ANIMATIONS ═══════════════ */
if(typeof gsap!=='undefined' && typeof ScrollTrigger!=='undefined'){
  gsap.registerPlugin(ScrollTrigger);

  /* --- Scroll Progress Bar --- */
  gsap.to('.scroll-prog',{scaleX:1,ease:'none',scrollTrigger:{trigger:'body',start:'top top',end:'bottom bottom',scrub:0.3}});

  /* --- Nav Scroll --- */
  ScrollTrigger.create({
    start:'top -80',
    onUpdate:function(self){
      var nav = document.getElementById('mainNav');
      if(!nav)return;
      if(self.scroll()>80) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    }
  });

  /* --- Hero Character Split --- */
  (function(){
    var title = document.getElementById('heroTitle');
    if(!title)return;
    var text = title.textContent.trim();
    var html = '';
    for(var i=0;i<text.length;i++){
      if(text[i]===' '){
        html += '<span class="word-space"> </span>';
      } else {
        html += '<span class="char">'+text[i]+'</span>';
      }
    }
    title.innerHTML = html;
    title.style.opacity = '1';

    gsap.from('.hero-title .char',{
      y:60, opacity:0, rotateX:-40,
      stagger:0.025, duration:0.7,
      ease:'back.out(1.4)',
      delay:0.3
    });
  })();

  /* --- Hero Sub & Actions --- */
  gsap.from('.hero-sub',{y:30,opacity:0,duration:0.8,delay:0.8,ease:'power2.out'});
  gsap.from('.hero-actions',{y:20,opacity:0,duration:0.7,delay:1.0,ease:'power2.out'});
  gsap.from('.hero-rating',{y:15,opacity:0,duration:0.6,delay:1.2,ease:'power2.out'});

  /* --- General Section Reveals --- */
  gsap.utils.toArray('.reveal-el').forEach(function(el){
    gsap.to(el,{
      y:0, opacity:1, duration:0.8,
      ease:'power2.out',
      scrollTrigger:{trigger:el, start:'top 88%', once:true}
    });
  });

  /* --- Horizontal Scroll (Services) — Desktop Only --- */
  if(!isMobile){
    var track = document.getElementById('svcTrack');
    var svcSec = document.getElementById('svcSec');
    if(track && svcSec){
      // Wait for layout
      ScrollTrigger.addEventListener('refresh',function(){});
      requestAnimationFrame(function(){
        var scrollDist = track.scrollWidth - window.innerWidth + 80;
        if(scrollDist > 0){
          gsap.to(track,{
            x: -scrollDist,
            ease:'none',
            scrollTrigger:{
              trigger:svcSec,
              pin:true,
              scrub:1,
              end:function(){return '+=' + scrollDist;},
              invalidateOnRefresh:true
            }
          });
        }
      });
    }
  }

  /* --- Counter Animation --- */
  document.querySelectorAll('.stat-num').forEach(function(el){
    var target = parseInt(el.getAttribute('data-count'),10);
    if(isNaN(target))return;
    ScrollTrigger.create({
      trigger:el,
      start:'top 85%',
      once:true,
      onEnter:function(){
        var obj = {val:0};
        gsap.to(obj,{
          val:target,
          duration:2.2,
          ease:'power2.out',
          onUpdate:function(){
            el.textContent = Math.round(obj.val).toLocaleString();
          }
        });
      }
    });
  });

  /* --- Gallery Stagger --- */
  gsap.utils.toArray('.gal-item').forEach(function(el,i){
    gsap.to(el,{
      y:0,opacity:1,duration:0.7,
      delay:i*0.1,
      ease:'power2.out',
      scrollTrigger:{trigger:el,start:'top 90%',once:true}
    });
  });

  /* --- Review Card Stagger --- */
  gsap.utils.toArray('.rev-card').forEach(function(el,i){
    gsap.to(el,{
      y:0,opacity:1,duration:0.7,
      delay:i*0.08,
      ease:'power2.out',
      scrollTrigger:{trigger:el,start:'top 90%',once:true}
    });
  });

  /* --- Service Card Stagger (mobile) --- */
  if(isMobile){
    gsap.utils.toArray('.svc-card').forEach(function(el,i){
      gsap.fromTo(el,{y:30,opacity:0},{
        y:0,opacity:1,duration:0.6,
        delay:i*0.08,
        ease:'power2.out',
        scrollTrigger:{trigger:el,start:'top 90%',once:true}
      });
    });
  }

  /* --- Process Steps Stagger --- */
  gsap.utils.toArray('.process-step').forEach(function(el,i){
    gsap.to(el,{
      y:0,opacity:1,duration:0.6,
      delay:i*0.15,
      ease:'power2.out',
      scrollTrigger:{trigger:el,start:'top 88%',once:true}
    });
  });
}

/* ═══════════════ FAQ ACCORDION ═══════════════ */
document.querySelectorAll('.faq-q').forEach(function(btn){
  btn.addEventListener('click',function(){
    var item = btn.closest('.faq-item');
    var answer = item.querySelector('.faq-a');
    var isOpen = item.classList.contains('open');

    // Close all others
    document.querySelectorAll('.faq-item.open').forEach(function(other){
      if(other!==item){
        other.classList.remove('open');
        other.querySelector('.faq-a').style.maxHeight = '0';
      }
    });

    if(isOpen){
      item.classList.remove('open');
      answer.style.maxHeight = '0';
    } else {
      item.classList.add('open');
      answer.style.maxHeight = answer.scrollHeight + 'px';
    }
  });
});

/* ═══════════════ MOBILE NAV TOGGLE ═══════════════ */
var ham = document.getElementById('hamBtn');
var navMenu = document.getElementById('navMenu');
if(ham && navMenu){
  ham.addEventListener('click',function(){
    navMenu.classList.toggle('open');
    ham.classList.toggle('active');
    document.body.style.overflow = navMenu.classList.contains('open') ? 'hidden' : '';
  });
  navMenu.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click',function(){
      navMenu.classList.remove('open');
      ham.classList.remove('active');
      document.body.style.overflow = '';
    });
  });
}

/* ═══════════════ CURSOR GLOW ═══════════════ */
(function(){
  var glow = document.querySelector('.cursor-glow');
  if(!glow || isMobile || !matchMedia('(hover:hover)').matches)return;
  document.addEventListener('mousemove',function(e){
    if(typeof gsap!=='undefined'){
      gsap.to(glow,{left:e.clientX,top:e.clientY,duration:0.8,ease:'power2.out'});
    } else {
      glow.style.left = e.clientX+'px';
      glow.style.top = e.clientY+'px';
    }
  },{passive:true});
})();

/* ═══════════════ SMOOTH SCROLL (anchor links) ═══════════════ */
document.querySelectorAll('a[href^="#"]').forEach(function(a){
  a.addEventListener('click',function(e){
    var id = a.getAttribute('href');
    if(id.length<2)return;
    var target = document.querySelector(id);
    if(!target)return;
    e.preventDefault();
    target.scrollIntoView({behavior:'smooth',block:'start'});
  });
});

})();
</script>
</body>
</html>